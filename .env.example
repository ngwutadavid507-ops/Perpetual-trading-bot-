# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_or_channel_id_here

# Exchanges to scan (comma separated): bybit, okx, bingx
EXCHANGES=bybit,okx,bingx

# Timeframe for candle analysis (ccxt format): 1m,5m,15m,1h,4h,1d
TIMEFRAME=15m

# Minimum 24h quote volume (USDT) for a symbol to be scanned — filters illiquid noise
MIN_24H_VOLUME_USDT=5000000

# Confidence thresholds (0-100). BTC requires a stricter bar than altcoins.
MIN_CONFIDENCE_DEFAULT=65
MIN_CONFIDENCE_BTC=85

# How often the scanner runs, in seconds
SCAN_INTERVAL_SECONDS=300

# Minimum reward:risk ratio required to fire a signal
MIN_RISK_REWARD=1.5
